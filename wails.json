{
  "$schema": "https://wails.io/schemas/config.v2.json",
  "name": "Aether",
  "version": "2",
  "frontend:dir": "frontend",
  "outputfilename": "Aether",
  "frontend:install": "npm install",
  "frontend:build": "npm run build",
  "frontend:dev:watcher": "npm run dev",
  "frontend:dev:serverUrl": "http://localhost:34115",
  "assetdir": "frontend/dist",
  "build:dir": "build",
  "nsisType": "multiple",
  "preBuildHooks": {
    "windows/amd64": "powershell.exe -Command \"go build -ldflags '-H=windowsgui' -o aether-core.exe ../../cmd/aether-core; Copy-Item ../../wintun.dll ./wintun.dll -Force\""
  },
  "author": {
    "name": "Aether",
    "email": "devnull@example.com"
  },
  "info": {
    "companyName": "Aether",
    "productName": "Aether",
    "productVersion": "0.1.0",
    "copyright": "Copyright (c) 2026 Aether",
    "comments": "Windows tray-first transparent proxy GUI built with Wails v2"
  },
  "nsis": {
    "installerMode": "currentUser"
  }
}
